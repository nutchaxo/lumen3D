# Prevent direct web access to the config file
<Files "config.php">
    Order Deny,Allow
    Deny from all
</Files>

# Protect ALL admin state files and PHP includes. dev_server.py blocks the whole
# api/ dir from static serving; on a raw Apache/PHP host these files would otherwise
# be downloadable. Denying every api/*.json (credentials, stats, plugin toggles,
# quarantine, and the OPERATOR TRUST STORE plugin-trust.json — which lists approved
# paths, pinned hashes, granted caps and the admin username) prevents this list from
# drifting as new state files are added. Nginx equivalent:
#   location ~* /api/.*\.json$ { deny all; }
#   location ~* /api/_admin_lib\.php$ { deny all; }
<FilesMatch "\.json$|^_admin_lib\.php$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
