# Environments
.venv-312/
.env
__pycache__/
*.pyc

# Local Python runtime bootstrapped by the self-contained preprocess launcher
.runtime/

# Datasets / Large files
DATA_WEB/*
!DATA_WEB/.gitkeep
*.nii
*.nii.gz
*.ome.tif
*.tif
*.tiff
*.dzi
*.db

# Work in progress / Personal files
DOCS/*
!DOCS/plugins/
!DOCS/update-system/
platform_data_inventory.xlsx
platform_preselection_fixed_live.xlsx
test_meta.html

# IDEs / assistant local state
.vscode/
.agents/
.idea/
.claude/settings.local.json

# Logs
logs/
*.log

# Admin runtime state (secret / machine-local — never commit)
api/config.json
api/admin_credential.json
api/stats.json
api/disabled-plugins.json

# Self-update backups + runtime artifacts (version.json ships in the release
# artifact and is written by updates — never tracked in git)
backups/
version.json
dist/

# One-file installer runtime state (install.php) — never commit
.install-state.json
.install-lock
.install-download.zip.part
